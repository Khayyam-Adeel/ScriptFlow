<ShowPlanXML xmlns="http://schemas.microsoft.com/sqlserver/2004/07/showplan" Version="1.2" Build="12.0.2269.0"><BatchSequence><Batch><Statements><StmtSimple StatementText="SELECT&#xa;    pl.Name AS PracticeLocation,&#xa;    SUM(CASE WHEN p.Status = 4 THEN 1 ELSE 0 END) AS RejectedCount,&#xa;    COUNT(*) AS FinalizedCount,&#xa;    CAST(100.0 * SUM(CASE WHEN p.Status = 4 THEN 1 ELSE 0 END) / COUNT(*) AS DECIMAL(5,2)) AS RejectionRatePct&#xa;FROM Prescription.tblPrescriptions p&#xa;JOIN Admin.tblPracticeLocations pl ON pl.Id = p.PracticeLocationId&#xa;WHERE p.Status IN (3, 4)&#xa;GROUP BY pl.Name" StatementId="1" StatementCompId="2" StatementType="SELECT" RetrievedFromCache="true" StatementSubTreeCost="6.46991" StatementEstRows="34" StatementOptmLevel="FULL" QueryHash="0x453245E53FFC19A4" QueryPlanHash="0xA2A4DC9DB9D1FC6C" CardinalityEstimationModelVersion="120"><StatementSetOptions QUOTED_IDENTIFIER="false" ARITHABORT="false" CONCAT_NULL_YIELDS_NULL="true" ANSI_NULLS="true" ANSI_PADDING="true" ANSI_WARNINGS="true" NUMERIC_ROUNDABORT="false"/><QueryPlan DegreeOfParallelism="0" MemoryGrant="1024" NonParallelPlanReason="NoParallelPlansInDesktopOrExpressEdition" CachedPlanSize="40" CompileTime="4" CompileCPU="4" CompileMemory="496"><MemoryGrantInfo SerialRequiredMemory="512" SerialDesiredMemory="544" RequiredMemory="512" DesiredMemory="544" RequestedMemory="1024" GrantWaitTime="0" GrantedMemory="1024" MaxUsedMemory="16"/><OptimizerHardwareDependentProperties EstimatedAvailableMemoryGrant="416115" EstimatedPagesCached="104028" EstimatedAvailableDegreeOfParallelism="2"/><RelOp NodeId="0" PhysicalOp="Compute Scalar" LogicalOp="Compute Scalar" EstimateRows="34" EstimateIO="0" EstimateCPU="3.4e-006" AvgRowSize="48" EstimatedTotalSubtreeCost="6.46991" Parallel="0" EstimateRebinds="0" EstimateRewinds="0" EstimatedExecutionMode="Row"><OutputList><ColumnReference Database="[ScriptFlow_DEV]" Schema="[Admin]" Table="[tblPracticeLocations]" Alias="[pl]" Column="Name"/><ColumnReferenc