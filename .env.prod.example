# Copy this to .env on the EC2 instance (same directory as docker-compose.yml) and
# fill in real values. Never commit the real .env - it's already covered by .gitignore
# rules for .env* if you add one, double check before committing anything.
#
# Generate strong values with: openssl rand -base64 32

MSSQL_SA_PASSWORD=
JWT_SIGNING_KEY=
RABBITMQ_USER=scriptflow
RABBITMQ_PASSWORD=

# Public IP or domain of the EC2 box, e.g. 3.10.45.201 or scriptflow.duckdns.org
PUBLIC_HOST=
